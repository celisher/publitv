generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)
  color     String?   @db.VarChar(20)
  icon      String?   @db.VarChar(50)
  active    Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  price       Decimal  @db.Decimal(10, 2)
  description String?  @db.VarChar(300)
  image       String?  @db.VarChar(500)
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  slug            String   @unique @db.VarChar(100)
  description     String?  @db.VarChar(300)
  bgImage         String?  @db.VarChar(500)
  bgColor         String   @default("#0d0d0d") @db.VarChar(20)
  overlayColor    String   @default("rgba(0,0,0,0.6)") @db.VarChar(50)
  primaryColor    String   @default("#ff4500") @db.VarChar(20)
  secondaryColor  String   @default("#d4ac0d") @db.VarChar(20)
  priceColor      String   @default("#ff4500") @db.VarChar(20)
  titleColor      String   @default("#ffffff") @db.VarChar(20)
  fontStyle       String   @default("bold") @db.VarChar(30)
  titleSize       String   @default("4xl") @db.VarChar(10)
  priceSize       String   @default("3xl") @db.VarChar(10)
  layout          String   @default("grid") @db.VarChar(30)
  logoPosition    String   @default("top-left") @db.VarChar(20)
  showBanner      Boolean  @default(true)
  bannerText      String?  @db.VarChar(200)
  bannerBgColor       String   @default("#c0392b") @db.VarChar(20)
  priceGlowIntensity  Int      @default(40)
  itemsPerPage        Int      @default(8)
  thumbnail           String?  @db.VarChar(500)
  active              Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  screens         Screen[]
}

model Screen {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(100)
  slug             String           @unique @db.VarChar(100)
  active           Boolean          @default(true)
  templateId       Int?
  template         Template?        @relation(fields: [templateId], references: [id])
  displayMode      String           @default("list") @db.VarChar(20)
  rotationInterval Int              @default(8)
  showPrices       Boolean          @default(true)
  categories       String           @default("[]") @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  screenPromotions ScreenPromotion[]
  promoSlides      PromoSlide[]
}

model Promotion {
  id          Int              @id @default(autoincrement())
  title       String           @db.VarChar(150)
  subtitle    String?          @db.VarChar(300)
  image       String?          @db.VarChar(500)
  type        String           @default("banner") @db.VarChar(30)
  active      Boolean          @default(true)
  priority    Int              @default(0)
  startDate   DateTime?
  endDate     DateTime?
  bgColor     String?          @db.VarChar(20)
  textColor   String?          @db.VarChar(20)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  screenPromotions ScreenPromotion[]
}

model ScreenPromotion {
  id          Int       @id @default(autoincrement())
  screenId    Int
  promotionId Int
  screen      Screen    @relation(fields: [screenId], references: [id], onDelete: Cascade)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([screenId, promotionId])
}

model PromoSlide {
  id           Int      @id @default(autoincrement())
  screenId     Int
  screen       Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  title        String   @db.VarChar(200)
  price        Decimal? @db.Decimal(10, 2)
  priceUnit    String   @default("$/kg") @db.VarChar(20)
  productImage String?  @db.VarChar(500)
  bgImage      String?  @db.VarChar(500)
  bgColor      String   @default("#c0392b") @db.VarChar(20)
  titleColor   String   @default("#ffffff") @db.VarChar(20)
  priceColor   String   @default("#ffdd00") @db.VarChar(20)
  accentColor  String   @default("#d4ac0d") @db.VarChar(20)
  active       Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(100)
  role      String   @default("admin") @db.VarChar(20)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
